# Environment variables for MCP Governance Hub
# Copy this file to .env for local overrides (not needed in Docker — use compose.yml instead).

# Absolute path that the Hub uses as the workspace root.
# In Docker this is set via the volume mount in compose.yml.
# Default: /projects
# PROJECTS_ROOT=/projects

# Set to "development" locally, "production" in Docker.
# Default: production
# NODE_ENV=development
